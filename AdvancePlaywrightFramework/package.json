{
  "name": "advance-playwright-framework",
  "version": "1.0.0",
  "description": "Advanced Playwright E2E Testing Framework with Page Object Model, Fixtures, and Best Practices",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:auth": "playwright test tests/e2e/auth",
    "test:dashboard": "playwright test tests/e2e/dashboard",
    "test:checkout": "playwright test tests/e2e/checkout",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\""
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "automation",
    "page-object-model",
    "fixtures"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}